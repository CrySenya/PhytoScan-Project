{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@phytoscan/shared": ["packages/shared/src"],
      "@phytoscan/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps/mobile",
    "apps/web"
  ]
}